-- Variables
local strengthFarmActive = false
local maxRebirthActive = false
local infMoneyActive = false
local auraSpamActive = false

-- Helper function for Egg/Event Opening
local function openEgg(eggName)
    local args = {eggName, 1}
    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("E&F"):WaitForChild("Luck"):WaitForChild("[C-S]DoLuck"):InvokeServer(unpack(args))
    end)
end

-- MAIN TAB: Strength, Money & Rebirth
MainTab:CreateToggle({
   Name = "Auto Farm Strength [On Machine]",
   CurrentValue = false,
   Flag = "StrengthToggle",
   Callback = function(Value)
      strengthFarmActive = Value
      if strengthFarmActive then
          task.spawn(function()
              local remote = game:GetService("ReplicatedStorage"):WaitForChild("E&F"):WaitForChild("Train"):WaitForChild("TrainOnceRE")
              while strengthFarmActive do
                  remote:FireServer(1.1462546426205953, false)
                  task.wait() 
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Get Inf Money [Super Fast]",
   CurrentValue = false,
   Flag = "MoneyToggle",
   Callback = function(Value)
      infMoneyActive = Value
      if infMoneyActive then
          task.spawn(function()
              local moneyRemote = game:GetService("ReplicatedStorage"):WaitForChild("E&F"):WaitForChild("Dig"):WaitForChild("CalculateDigCoinsRF")
              while infMoneyActive do
                  moneyRemote:InvokeServer()
                  task.wait() 
              end
          end)

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "BigRig's BrainRot Hub",
   LoadingTitle = "Loading...",
   LoadingSubtitle = "by BigRig",
   ConfigurationSaving = {
      Enabled = false,
      FolderName = "BrainrotHub", 
      FileName = "MainConfig"
   },
   KeySystem = false
})

-- Variables for Toggles
local Flags = {
    Money = false,
    Speed = false,
    Rebirth = false,
    ESP = {}
}

-- Remotes
local MoneyRemote = game:GetService("ReplicatedStorage"):WaitForChild("Shared"):WaitForChild("Remotes"):WaitForChild("Networking"):WaitForChild("RF/PlotAction")
local SpeedRemote = game:GetService("ReplicatedStorage"):WaitForChild("RemoteFunctions"):WaitForChild("UpgradeSpeed")
local RebirthRemote = game:GetService("ReplicatedStorage"):WaitForChild("RemoteFunctions"):WaitForChild("Rebirth")

-- ESP Settings/Logic
local Rarities = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythical", "Cosmic", "Secret"}
local Colors = {
    Common = Color3.new(0.8, 0.8, 0.8),
    Uncommon = Color3.new(0.2, 0.8, 0.2),
    Rare = Color3.new(0, 0.5, 1),
    Epic = Color3.new(0.6, 0.2, 0.9),
    Legendary = Color3.new(1, 0.7, 0),
    Mythical = Color3.new(1, 0, 0.6),
    Cosmic = Color3.new(0, 1, 1),
    Secret = Color3.new(1, 0, 0)
}

local function applyHighlight(obj, rarity)
    if not obj:FindFirstChild("BrotHighlight") then
        local h = Instance.new("Highlight")
        h.Name = "BrotHighlight"
        h.FillTransparency = 0.4
        h.OutlineTransparency = 0
        h.FillColor = Colors[rarity] or Color3.new(1,1,1)
        h.Parent = obj
    end
end

local function removeHighlight(obj)
    local h = obj:FindFirstChild("BrotHighlight")
    if h then h:Destroy() end
end

local function refreshESP()
    local folder = workspace:FindFirstChild("ActiveBrainrots")
    if not folder then return end
    for _, rarityFolder in pairs(folder:GetChildren()) do
        local rName = rarityFolder.Name
        local isEnabled = Flags.ESP[rName]
        for _, item in pairs(rarityFolder:GetChildren()) do
            if isEnabled then applyHighlight(item, rName) else removeHighlight(item) end
        end
    end
end

--- TABS ---
local MainTab = Window:CreateTab("Main Features", 4483362458) -- Home Icon
local ESPTab = Window:CreateTab("ESP Visuals", 4483345998) -- Eye Icon

--- MAIN FEATURES ---
MainTab:CreateSection("Automation")

MainTab:CreateToggle({
   Name = "Auto Collect Money",
   CurrentValue = false,
   Flag = "ToggleMoney",
   Callback = function(Value)
      Flags.Money = Value
      if Value then
          task.spawn(function()
              while Flags.Money do
                  local Bases = workspace:FindFirstChild("Bases")
                  if Bases then
                      for _, base in pairs(Bases:GetChildren()) do
                          task.spawn(function()
                              for i = 1, 40 do
                                  if not Flags.Money then break end
                                  pcall(function() 
                                      MoneyRemote:InvokeServer("Collect Money", base.Name, tostring(i)) 
                                  end)
                              end
                          end)
                      end
                  end
                  task.wait(0.3)
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto Upgrade Speed",
   CurrentValue = false,
   Flag = "ToggleSpeed",
   Callback = function(Value)
      Flags.Speed = Value
      if Value then
          task.spawn(function()
              while Flags.Speed do
                  pcall(function() SpeedRemote:InvokeServer(1) end)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto Rebirth",
   CurrentValue = false,
   Flag = "ToggleRebirth",
   Callback = function(Value)
      Flags.Rebirth = Value
      if Value then
          task.spawn(function()
              while Flags.Rebirth do
                  pcall(function() RebirthRemote:InvokeServer() end)
                  task.wait(0.5)
              end
          end)
      end
   end,
})

--- ESP FEATURES ---
ESPTab:CreateSection("Rarity ESP")

for _, rarity in pairs(Rarities) do
    Flags.ESP[rarity] = false
    ESPTab:CreateToggle({
        Name = rarity .. " Highlight",
        CurrentValue = false,
        Flag = "ESP_" .. rarity,
        Callback = function(Value)
            Flags.ESP[rarity] = Value
            refreshESP()
        end,
    })
end

-- Spawn Listener for ESP
task.spawn(function()
    local folder = workspace:WaitForChild("ActiveBrainrots")
    for _, rarityFolder in pairs(folder:GetChildren()) do
        rarityFolder.ChildAdded:Connect(function(item)
            task.wait(0.1)
            if Flags.ESP[rarityFolder.Name] then
                applyHighlight(item, rarityFolder.Name)
            end
        end)
    end
end)


-- ESP Logic (Rarities)
local Rarities = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythical", "Cosmic", "Secret"}
local ESP_Settings = { All = false }
local Colors = {
    Common = Color3.new(0.8, 0.8, 0.8),
    Uncommon = Color3.new(0.2, 0.8, 0.2),
    Rare = Color3.new(0, 0.5, 1),
    Epic = Color3.new(0.6, 0.2, 0.9),
    Legendary = Color3.new(1, 0.7, 0),
    Mythical = Color3.new(1, 0, 0.6),
    Cosmic = Color3.new(0, 1, 1),
    Secret = Color3.new(1, 0, 0)
}

local function applyHighlight(obj, rarity)
    if not obj:FindFirstChild("BrotHighlight") then
        local h = Instance.new("Highlight")
        h.Name = "BrotHighlight"
        h.FillTransparency = 0.4
        h.OutlineTransparency = 0
        h.FillColor = Colors[rarity] or Color3.new(1,1,1)
        h.Parent = obj
    end
end

local function removeHighlight(obj)
    local h = obj:FindFirstChild("BrotHighlight")
    if h then h:Destroy() end
end

local function refreshAll()
    local folder = workspace:FindFirstChild("ActiveBrainrots")
    if not folder then return end
    for _, rarityFolder in pairs(folder:GetChildren()) do
        local rName = rarityFolder.Name
        local isEnabled = ESP_Settings.All or ESP_Settings[rName]
        for _, item in pairs(rarityFolder:GetChildren()) do
            if isEnabled then applyHighlight(item, rName) else removeHighlight(item) end
        end
    end
end

ToggleESPMenu.MouseButton1Click:Connect(function()
    ESPFrame.Visible = not ESPFrame.Visible
    ToggleESPMenu.Text = ESPFrame.Visible and "<< Hide ESP" or "ESP Rarities >>"
end)

for i, rarity in pairs(Rarities) do
    local btn = Instance.new("TextButton")
    ESP_Settings[rarity] = false
    StyleButton(btn, ESPFrame, 35 + (i-1)*40, rarity..": OFF", Color3.fromRGB(60, 60, 60))
    btn.MouseButton1Click:Connect(function()
        ESP_Settings[rarity] = not ESP_Settings[rarity]
        btn.Text = rarity .. (ESP_Settings[rarity] and ": ON" or ": OFF")
        btn.BackgroundColor3 = ESP_Settings[rarity] and Color3.fromRGB(40, 160, 40) or Color3.fromRGB(60, 60, 60)
        refreshAll()
    end)
end

local AllBtn = Instance.new("TextButton")
StyleButton(AllBtn, ESPFrame, 35 + (#Rarities)*40, "TOGGLE ALL: OFF", Color3.fromRGB(80, 20, 20))
AllBtn.MouseButton1Click:Connect(function()
    ESP_Settings.All = not ESP_Settings.All
    AllBtn.Text = ESP_Settings.All and "TOGGLE ALL: ON" or "TOGGLE ALL: OFF"
    AllBtn.BackgroundColor3 = ESP_Settings.All and Color3.fromRGB(40, 160, 40) or Color3.fromRGB(80, 20, 20)
    refreshAll()
end)

-- Spawn Listener for ESP
task.spawn(function()
    local folder = workspace:WaitForChild("ActiveBrainrots")
    for _, rarityFolder in pairs(folder:GetChildren()) do
        rarityFolder.ChildAdded:Connect(function(item)
            task.wait(0.1)
            if ESP_Settings.All or ESP_Settings[rarityFolder.Name] then
                applyHighlight(item, rarityFolder.Name)
            end
        end)
    end
end)

-- REBUILT FASTER MONEY COLLECTOR
local MoneyRemote = game:GetService("ReplicatedStorage"):WaitForChild("Shared"):WaitForChild("Remotes"):WaitForChild("Networking"):WaitForChild("RF/PlotAction")
local SpeedRemote = game:GetService("ReplicatedStorage"):WaitForChild("RemoteFunctions"):WaitForChild("UpgradeSpeed")
local RebirthRemote = game:GetService("ReplicatedStorage"):WaitForChild("RemoteFunctions"):WaitForChild("Rebirth")

local MoneyRunning = false
local SpeedRunning = false
local RebirthRunning = false

ToggleMoney.MouseButton1Click:Connect(function()
    MoneyRunning = not MoneyRunning
    ToggleMoney.Text = MoneyRunning and "Money: FAST" or "Money: OFF"
    ToggleMoney.BackgroundColor3 = MoneyRunning and Color3.fromRGB(40, 160, 40) or Color3.fromRGB(180, 40, 40)
    
    if MoneyRunning then
        task.spawn(function()
            while MoneyRunning do
                local Bases = workspace:FindFirstChild("Bases")
                if Bases then
                    for _, base in pairs(Bases:GetChildren()) do
                        -- Spawn a separate thread for EACH base to prevent lag/delays
                        task.spawn(function()
                            for i = 1, 40 do
                                if not MoneyRunning then break end
                                pcall(function() 
                                    -- Directly firing "1" to "40" as strings
                                    MoneyRemote:InvokeServer("Collect Money", base.Name, tostring(i)) 
                                end)
                            end
                        end)
                    end
                end
                task.wait(0.3) -- Small delay to prevent server kick for spam, but multi-threaded
            end
        end)
    end
end)


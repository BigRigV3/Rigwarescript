-- [[ UTILITIES ]] --

local function SafeConnect(signal, callback)

    local conn = signal:Connect(callback)

    table.insert(RigWare_Registry.Connections, conn)

    return conn

end



local function SafeDraw(obj, prop)

    local drawing = Drawing.new(obj)

    for i, v in pairs(prop) do

        drawing[i] = v

    end

    table.insert(RigWare_Registry.Drawings, drawing)

    return drawing

end



local function GetUniversalCharacter(Player)

    if Player.Character then

        return Player.Character

    end



    local char = workspace:FindFirstChild(Player.Name)

    if char and (char:IsA("Model") or char:IsA("Folder")) then

        return char

    end



    for _, v in pairs(workspace:GetChildren()) do

        if v.Name == Player.Name and (v:IsA("Model") or v:IsA("Folder")) then

            return v

        end

    end



    return nil

end



local function GetUniversalPart(Character, PartName)

    if not Character then

        return nil

    end



    local found = Character:FindFirstChild(PartName, true)

    if found and found:IsA("BasePart") then

        return found

    end



    local fallbacks = { "Hitbox", "Head", "UpperTorso", "HumanoidRootPart", "Torso", "Humanoid" }

    for _, name in ipairs(fallbacks) do

        local part = Character:FindFirstChild(name, true)

        if part and part:IsA("BasePart") then

            return part

        end

    end



    return nil

end



local function GetClosestPart(Character)

    local closestPart = nil

    local shortestDist = math.huge

    local mousePos = UserInputService:GetMouseLocation()



    for _, part in pairs(Character:GetDescendants()) do

        if part:IsA("BasePart") then

            local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)

            if onScreen then

                local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude

                if dist < shortestDist then

                    shortestDist = dist

                    closestPart = part

                end

            end

        end

    end



    return closestPart or GetUniversalPart(Character, "Head")

end



local function GetBindValue()

    local flags = Library.Flags or {}

    local binding = flags.Aim_Key



    if typeof(binding) == "table" then

        return binding.Value or binding.Key or binding[1]

    end



    return binding

end




-- [[ INPUT LOGIC ]] --

SafeConnect(UserInputService.InputBegan, function(i, p)

    if p then

        return

    end



    local bindKey = GetBindValue()

    if not bindKey then

        return

    end



    if i.KeyCode == bindKey or i.UserInputType == bindKey then

        if AIMBOT_MODE == "Hold" then

            holding = true

        elseif AIMBOT_MODE == "Toggle" then

            holding = not holding

        end

    end

end)



SafeConnect(UserInputService.InputEnded, function(i)

    local bindKey = GetBindValue()

    if not bindKey then

        return

    end



    if (i.KeyCode == bindKey or i.UserInputType == bindKey) and AIMBOT_MODE == "Hold" then

        holding = false

    end

end)



SafeConnect(UserInputService.JumpRequest, function()

    if INF_JUMP and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then

        LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)

    end

end)



for _, p in pairs(Players:GetPlayers()) do

    CreateVisuals(p)

end

local function CreateVisuals(Player)

    local Box = SafeDraw("Square", { Thickness = 1, Visible = false, ZIndex = 10 })

    local BoxOutline = SafeDraw("Square", { Thickness = 3, Color = Color3.new(0, 0, 0), Visible = false, ZIndex = 9 })

    local NameTag = SafeDraw("Text", { Size = 13, Center = true, Outline = true, Visible = false, ZIndex = 10 })

    local HealthBar = SafeDraw("Square", { Thickness = 1, Filled = true, Visible = false, ZIndex = 10 })

    local HealthBarBack = SafeDraw("Square", { Thickness = 1, Filled = true, Color = Color3.new(0, 0, 0), Visible = false, ZIndex = 9 })

    local Tracer = SafeDraw("Line", { Thickness = 1, Visible = false, ZIndex = 10 })

    local HeadDot = SafeDraw("Circle", { Filled = true, NumSides = 12, Visible = false, ZIndex = 10 })



    local CornerLines = {}

    for i = 1, 8 do

        CornerLines[i] = SafeDraw("Line", { Thickness = 1, Visible = false, ZIndex = 10 })

    end



    local SkeletonLines = {}

    local SkeletonOutlines = {}

    for i = 1, #BoneStructure do

        SkeletonLines[i] = SafeDraw("Line", { Thickness = 1.5, Visible = false, ZIndex = 10 })

        SkeletonOutlines[i] = SafeDraw("Line", { Thickness = 3, Color = Color3.new(0, 0, 0), Visible = false, ZIndex = 9 })

    end



    SafeConnect(RunService.RenderStepped, function()

        local char = GetUniversalCharacter(Player)

        local root = GetUniversalPart(char, "HumanoidRootPart")

        local hum = char and char:FindFirstChildOfClass("Humanoid")

        local color = RAINBOW_ESP and MainColor or BoxColor



        if root and (Player ~= LocalPlayer or SELF_ESP) then

            if TEAM_CHECK and Player.Team == LocalPlayer.Team and Player ~= LocalPlayer then

                -- Skip teammates.

            else

                local distance = (root.Position - Camera.CFrame.Position).Magnitude

                if distance <= ESP_DISTANCE then

                    local Pos, OnScreen = Camera:WorldToViewportPoint(root.Position)

                    if OnScreen then

                        local Top = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 2.5, 0))

                        local Bottom = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.2, 0))

                        local H, W = Bottom.Y - Top.Y, (Bottom.Y - Top.Y) / 1.6

                        local X, Y = Pos.X - W / 2, Top.Y



                        if ESP_ENABLED and not CORNER_BOX then

                            Box.Visible = true

                            Box.Size = Vector2.new(W, H)

                            Box.Position = Vector2.new(X, Y)

                            Box.Color = color

                            Box.Transparency = BOX_FILLED and BOX_OPACITY or 1

                            Box.Filled = BOX_FILLED

                            BoxOutline.Visible = OUTLINES

                            BoxOutline.Size = Box.Size

                            BoxOutline.Position = Box.Position

                        else

                            Box.Visible = false

                            BoxOutline.Visible = false

                        end



                        if CORNER_BOX and ESP_ENABLED then

                            local L = W / 4

                            local cl = {

                                { Vector2.new(X, Y), Vector2.new(X + L, Y) },

                                { Vector2.new(X, Y), Vector2.new(X, Y + L) },

                                { Vector2.new(X + W, Y), Vector2.new(X + W - L, Y) },

                                { Vector2.new(X + W, Y), Vector2.new(X + W, Y + L) },

                                { Vector2.new(X, Y + H), Vector2.new(X + L, Y + H) },

                                { Vector2.new(X, Y + H), Vector2.new(X, Y + H - L) },

                                { Vector2.new(X + W, Y + H), Vector2.new(X + W - L, Y + H) },

                                { Vector2.new(X + W, Y + H), Vector2.new(X + W, Y + H - L) }

                            }

                            for i, v in pairs(CornerLines) do

                                v.Visible = true

                                v.From = cl[i][1]

                                v.To = cl[i][2]

                                v.Color = color

                            end

                        else

                            for _, v in pairs(CornerLines) do

                                v.Visible = false

                            end

                        end



                        NameTag.Visible = NAME_ENABLED

                        NameTag.Text = Player.Name

                        NameTag.Position = Vector2.new(Pos.X, Y - 15)

                        NameTag.Color = NameColor



                        if HEALTHBAR_ENABLED and hum then

                            local hp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)

                            HealthBarBack.Visible = true

                            HealthBarBack.Size = Vector2.new(4, H)

                            HealthBarBack.Position = Vector2.new(X - 6, Y)

                            HealthBar.Visible = true

                            HealthBar.Size = Vector2.new(2, hp * H)

                            HealthBar.Position = Vector2.new(X - 5, Bottom.Y - (hp * H))

                            HealthBar.Color = HealthColor

                        else

                            HealthBar.Visible = false

                            HealthBarBack.Visible = false

                        end



                        if SKELETON_ENABLED and char then

                            for i, bone in ipairs(BoneStructure) do

                                local p1 = char:FindFirstChild(bone[1], true)

                                local p2 = char:FindFirstChild(bone[2], true)

                                if p1 and p2 then

                                    local v1, os1 = Camera:WorldToViewportPoint(p1.Position)

                                    local v2, os2 = Camera:WorldToViewportPoint(p2.Position)

                                    if os1 and os2 then

                                        SkeletonLines[i].Visible = true

                                        SkeletonLines[i].From = Vector2.new(v1.X, v1.Y)

                                        SkeletonLines[i].To = Vector2.new(v2.X, v2.Y)

                                        SkeletonLines[i].Color = RAINBOW_ESP and MainColor or SkeletonColor

                                        SkeletonOutlines[i].Visible = OUTLINES

                                        SkeletonOutlines[i].From = SkeletonLines[i].From

                                        SkeletonOutlines[i].To = SkeletonLines[i].To

                                    else

                                        SkeletonLines[i].Visible = false

                                        SkeletonOutlines[i].Visible = false

                                    end

                                else

                                    SkeletonLines[i].Visible = false

                                    SkeletonOutlines[i].Visible = false

                                end

                            end

                        else

                            for i = 1, #SkeletonLines do

                                SkeletonLines[i].Visible = false

                                SkeletonOutlines[i].Visible = false

                            end

                        end



                        if TRACERS_ENABLED then

                            local mousePos = UserInputService:GetMouseLocation()

                            local Origin = (TRACER_ORIGIN == "Bottom" and Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y))

                                or (TRACER_ORIGIN == "Top" and Vector2.new(Camera.ViewportSize.X / 2, 0))

                                or mousePos

                            Tracer.Visible = true

                            Tracer.From = Origin

                            Tracer.To = Vector2.new(Pos.X, Pos.Y)

                            Tracer.Color = RAINBOW_ESP and MainColor or TracerColor

                        else

                            Tracer.Visible = false

                        end



                        if HEADDOT_ENABLED and char:FindFirstChild("Head") then

                            local hP, hO = Camera:WorldToViewportPoint(char.Head.Position)

                            HeadDot.Visible = hO

                            HeadDot.Position = Vector2.new(hP.X, hP.Y)

                            HeadDot.Radius = math.clamp(100 / Pos.Z, 2, 6)

                            HeadDot.Color = RAINBOW_ESP and MainColor or HeadDotColor

                        else

                            HeadDot.Visible = false

                        end



                        return

                    end

                end

            end

        end



        Box.Visible = false

        BoxOutline.Visible = false

        NameTag.Visible = false

        HealthBar.Visible = false

        HealthBarBack.Visible = false

        Tracer.Visible = false

        HeadDot.Visible = false

        for _, v in pairs(CornerLines) do

            v.Visible = false

        end

        for _, v in pairs(SkeletonLines) do

            v.Visible = false

        end

        for _, v in pairs(SkeletonOutlines) do

            v.Visible = false

        end

    end)

end



-- [[ MAIN LOOP ]] --

SafeConnect(RunService.RenderStepped, function(dt)

    local mousePos = UserInputService:GetMouseLocation()

    FOVOutline.Visible = SHOW_FOV

    FOVOutline.Radius = FOV_RADIUS

    FOVOutline.Position = mousePos



    FOVCircle.Visible = SHOW_FOV

    FOVCircle.Radius = FOV_RADIUS

    FOVCircle.Position = mousePos

    FOVCircle.Color = FOV_COLOR



    FOVFill.Visible = SHOW_FOV and FOV_FILLED

    FOVFill.Radius = FOV_RADIUS

    FOVFill.Position = mousePos

    FOVFill.Color = FOV_COLOR

    FOVFill.Transparency = FOV_OPACITY



    local IsAiming = false

    if AIMBOT_MODE == "Always" then

        IsAiming = true

    elseif AIMBOT_MODE == "Toggle" then

        IsAiming = holding

    elseif AIMBOT_MODE == "Hold" then

        local bindKey = GetBindValue()

        if typeof(bindKey) == "EnumItem" then

            if bindKey.EnumType == Enum.KeyCode then

                IsAiming = UserInputService:IsKeyDown(bindKey)

            elseif bindKey.EnumType == Enum.UserInputType then

                IsAiming = UserInputService:IsMouseButtonPressed(bindKey)

            end

        end

    end



    if (AIMBOT_MASTER or CURSOR_AIMBOT) and IsAiming then

        local BestTarget, MaxScore = nil, math.huge

        for _, p in pairs(Players:GetPlayers()) do

            local char = GetUniversalCharacter(p)

            local root = GetUniversalPart(char, "HumanoidRootPart")

            if p ~= LocalPlayer and char and root then

                if TEAM_CHECK and p.Team == LocalPlayer.Team then

                    continue

                end



                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(root.Position)

                local Dist = (root.Position - Camera.CFrame.Position).Magnitude

                if OnScreen and Dist <= AIM_DISTANCE then

                    local MouseDist = (Vector2.new(ScreenPos.X, ScreenPos.Y) - mousePos).Magnitude

                    if MouseDist <= FOV_RADIUS then

                        local Score = (TARGET_PRIORITY == "Mouse") and MouseDist or Dist

                        if Score < MaxScore then

                            MaxScore = Score

                            BestTarget = p

                        end

                    end

                end

            end

        end



        if BestTarget then

            local char = GetUniversalCharacter(BestTarget)

            local part = (AIM_PART == "Closest") and GetClosestPart(char) or GetUniversalPart(char, AIM_PART)

            if part then

                local Final = part.Position + (PREDICTION_ENABLED and (part.Velocity * PREDICTION_VALUE) or Vector3.zero)



                if CURSOR_AIMBOT then

                    local targetPos = Camera:WorldToViewportPoint(Final)

                    local moveX = (targetPos.X - mousePos.X) * SMOOTHNESS

                    local moveY = (targetPos.Y - mousePos.Y) * SMOOTHNESS

                    if mousemoverel then

                        mousemoverel(moveX, moveY)

                    end

                else

                    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Final), SMOOTHNESS)

                end

            end

        end

    end



    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    if flying and root then

        root.Velocity = Vector3.zero

        local moveDir = Vector3.zero

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Camera.CFrame.LookVector end

        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - Camera.CFrame.LookVector end

        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - Camera.CFrame.RightVector end

        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Camera.CFrame.RightVector end

        if moveDir.Magnitude > 0 then

            root.CFrame = root.CFrame + (moveDir.Unit * flySpeed * dt)

        end

    end

end)



